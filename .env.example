# Copie ce fichier en « .env » et remplis avec les valeurs de TON projet Firebase.
# (Firebase Console -> Paramètres du projet -> Tes applications -> SDK setup)
# Ne committe JAMAIS le vrai fichier .env (il est déjà dans .gitignore).

VITE_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ton-projet
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
